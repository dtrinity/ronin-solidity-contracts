{
  "extends": "solhint:recommended",
  "rules": {
    "max-line-length": ["error", 180],
    "compiler-version": "off",
    "no-global-import": "off",
    "func-name-mixedcase": "off",
    "gas-custom-errors": "off",
    "immutable-vars-naming": "off",
    "func-visibility": "off",
    "var-name-mixedcase": "off",
    "reason-string": "off"
  }
}
